[Unit]
Description=O3 App Laravel Scheduler (one-shot, fired every minute by the timer)
After=network.target mysql.service

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/var/www/O3_app
ExecStart=/usr/bin/php artisan schedule:run --no-interaction

# Logs to journald (view with: journalctl -u o3-scheduler -f)
StandardOutput=journal
StandardError=journal
